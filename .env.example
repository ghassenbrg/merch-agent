# Local mode is unauthenticated and intended for localhost only.
MERCH_AGENT_ENV=local
MERCH_AGENT_EXPOSED=false
MERCH_AGENT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MERCH_AGENT_TRUSTED_HOSTS=localhost,127.0.0.1,::1

# Required when MERCH_AGENT_ENV=production/staging or MERCH_AGENT_EXPOSED=true.
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
MERCH_AGENT_API_TOKEN=

MERCH_AGENT_RATE_LIMIT_PER_MINUTE=240
MERCH_AGENT_WRITE_RATE_LIMIT_PER_MINUTE=60
MERCH_AGENT_LOG_MAX_BYTES=1000000
MERCH_AGENT_LOG_BACKUP_COUNT=5
MERCH_AGENT_LOG_RETENTION_DAYS=30

MERCH_AGENT_DATA_DIR=/app/data
MERCH_AGENT_BACKEND_HOST=127.0.0.1
MERCH_AGENT_BACKEND_PORT=8000
NUXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NUXT_PUBLIC_API_TOKEN=
